# Postgres
POSTGRES_USER=sprachbaum
POSTGRES_PASSWORD=sprachbaum
POSTGRES_DB=sprachbaum_dev
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://sprachbaum:sprachbaum@localhost:5432/sprachbaum_dev
REDIS_URL=redis://redis:6379
# Origen exacto (protocolo+host+puerto) del front, para el enableCors del
# backend. Usado por el navegador del usuario, no por la red interna de
# Docker — igual que NEXT_PUBLIC_API_URL pero en la dirección contraria.
# En local debe coincidir con el puerto real en el que corra `next dev` (no
# asumas 3000: si está ocupado, Next usa el siguiente libre). En producción,
# el dominio de Vercel. Obligatorio si NODE_ENV=production (el backend no
# arranca sin él).
CORS_ORIGIN=http://localhost:3000
# DSN del proyecto Sentry del backend (apps/api). Vacío en local para no reportar ruido de desarrollo.
SENTRY_DSN_API=

# Web
WEB_PORT=3000
# URL usada por el navegador del usuario, no por la red interna de Docker.
NEXT_PUBLIC_API_URL=http://localhost:4000
# DSN del proyecto Sentry del frontend (apps/web). Pública a propósito: el DSN
# de Sentry no es un secreto, solo un identificador de endpoint.
NEXT_PUBLIC_SENTRY_DSN_WEB=
